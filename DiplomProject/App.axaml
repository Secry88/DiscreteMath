<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DiplomProject.App"
             xmlns:local="using:DiplomProject"
             RequestedThemeVariant="Light">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://DiplomProject/CustomControls/MenuCardControl.axaml"/>
        <StyleInclude Source="avares://DiplomProject/CustomControls/TheoryCategoryCardControl.axaml"/>
    </Application.Styles>
</Application>