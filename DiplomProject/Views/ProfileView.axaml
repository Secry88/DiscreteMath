<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="650"
             xmlns:vm="using:DiplomProject.ViewModels"
             xmlns:conv="using:DiplomProject.Converters"
             x:DataType="vm:ProfileViewModel"
             x:Class="DiplomProject.Views.ProfileView">

    <Grid Background="#F5F5F7" RowDefinitions="Auto,*" Margin="40,24,40,32">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,20" ColumnSpacing="16">
            <Button Grid.Column="0"
                    HorizontalAlignment="Left" VerticalAlignment="Center"
                    Padding="0" Background="Transparent" BorderThickness="0"
                    Command="{Binding NavigateBackCommand}">
                <TextBlock Text="← На главную" FontSize="17" Foreground="#6E6785"/>
            </Button>
            <TextBlock Grid.Column="1" Text="Профиль"
                       FontSize="36" FontWeight="SemiBold"
                       Foreground="#6D28D9" VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="300,*" ColumnSpacing="20">

            <!-- Left panel: avatar + info -->
            <Border Grid.Column="0" Background="White" BorderBrush="#E9D5FF" BorderThickness="1.2"
                    CornerRadius="20" BoxShadow="0 4 14 0 #18000000">
                <StackPanel>
                    <!-- Avatar area -->
                    <Border Height="130" Background="#EDE9FE" CornerRadius="20,20,0,0">
                        <Grid>
                            <!-- Placeholder circle when no photo -->
                            <Border Width="100" Height="100" CornerRadius="50"
                                    Background="#7C3AED"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    IsVisible="{Binding !HasPhoto}">
                                <TextBlock Text="👤" FontSize="44"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <!-- Photo when available -->
                            <Border Width="100" Height="100" CornerRadius="50"
                                    ClipToBounds="True"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    IsVisible="{Binding HasPhoto}">
                                <Image Source="{Binding ProfileImageBase64,
                                           Converter={StaticResource Base64ImageConverter}}"
                                       Stretch="UniformToFill"/>
                            </Border>
                        </Grid>
                    </Border>

                    <StackPanel Margin="20,16,20,20" Spacing="10">
                        <!-- FIO with wrap to avoid overflow -->
                        <TextBlock Text="{Binding FullName}"
                                   FontSize="20" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Foreground="#1A1625"/>
                        <TextBlock Text="{Binding GroupName}"
                                   FontSize="13" Foreground="#6E6785"
                                   HorizontalAlignment="Center" TextWrapping="Wrap"
                                   TextAlignment="Center"/>

                        <!-- Change photo button -->
                        <Button Content="Изменить фото"
                                Click="OnChangePhotoClick"
                                HorizontalAlignment="Stretch"
                                Padding="0,10" Background="#F9F8FD"
                                BorderBrush="#D9D3EA" BorderThickness="1.5"
                                CornerRadius="12" FontSize="14"
                                FontWeight="SemiBold" Foreground="#6D28D9"/>

                        <Border Background="#F5F3FA" CornerRadius="10" Padding="12,8">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Логин" FontSize="11" Foreground="#9CA3AF"/>
                                <TextBlock Text="{Binding Login}" FontSize="14" Foreground="#1A1625"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#F5F3FA" CornerRadius="10" Padding="12,8">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Роль" FontSize="11" Foreground="#9CA3AF"/>
                                <TextBlock Text="{Binding RoleName}" FontSize="14" Foreground="#1A1625"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Right panel -->
            <StackPanel Grid.Column="1" Spacing="16">

                <!-- Stats -->
                <Border Background="White" BorderBrush="#E9D5FF" BorderThickness="1.2"
                        CornerRadius="20" Padding="22" BoxShadow="0 4 14 0 #18000000">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Прогресс обучения" FontSize="20" FontWeight="SemiBold" Foreground="#1A1625"/>
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                            <Border Grid.Column="0" Background="#F5F3FA" BorderBrush="#E9D5FF"
                                    BorderThickness="1" CornerRadius="14" Padding="14,12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Темы изучены" FontSize="12" Foreground="#6E6785"/>
                                    <TextBlock Text="{Binding LessonsCompletedText}"
                                               FontSize="22" FontWeight="SemiBold" Foreground="#7C3AED"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="#F5F3FA" BorderBrush="#E9D5FF"
                                    BorderThickness="1" CornerRadius="14" Padding="14,12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Тестов пройдено" FontSize="12" Foreground="#6E6785"/>
                                    <TextBlock Text="{Binding TestsCompleted}"
                                               FontSize="22" FontWeight="SemiBold" Foreground="#7C3AED"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="#F5F3FA" BorderBrush="#E9D5FF"
                                    BorderThickness="1" CornerRadius="14" Padding="14,12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Средний балл" FontSize="12" Foreground="#6E6785"/>
                                    <TextBlock Text="{Binding AverageScoreText}"
                                               FontSize="22" FontWeight="SemiBold" Foreground="#7C3AED"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Recent tests -->
                <Border Background="White" BorderBrush="#E9D5FF" BorderThickness="1.2"
                        CornerRadius="20" Padding="22" BoxShadow="0 4 14 0 #18000000">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Последние тесты" FontSize="20" FontWeight="SemiBold" Foreground="#1A1625"/>

                        <TextBlock IsVisible="{Binding !HasRecentTests}"
                                   Text="Вы ещё не проходили тесты"
                                   FontSize="14" Foreground="#9CA3AF"/>

                        <ItemsControl ItemsSource="{Binding RecentTests}" IsVisible="{Binding HasRecentTests}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FAFAFA" BorderBrush="#E9D5FF" BorderThickness="1"
                                            CornerRadius="12" Padding="14,10" Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Spacing="3">
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="14" FontWeight="SemiBold"
                                                           Foreground="#1A1625" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding DateText}"
                                                           FontSize="12" Foreground="#9CA3AF"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding ResultText}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="#7C3AED" VerticalAlignment="Center"
                                                       Margin="12,0,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
