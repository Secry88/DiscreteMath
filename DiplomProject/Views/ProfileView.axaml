<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="using:DiplomProject.ViewModels"
             x:DataType="vm:ProfileViewModel"
             x:Class="DiplomProject.Views.ProfileView">
    <Grid Background="#F5F5F7" RowDefinitions="Auto,*" Margin="24,16,24,20">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,14" ColumnSpacing="12">
            <Button Grid.Column="0"
                    Content="← Dashboard"
                    Command="{Binding NavigateBackCommand}"
                    Padding="16,10"
                    CornerRadius="12"
                    BorderBrush="#B9A4EC"
                    BorderThickness="1.2"
                    Background="#F9F8FD"/>
            <TextBlock Grid.Column="1"
                       Text="My Profile"
                       FontSize="42"
                       FontWeight="SemiBold"
                       Foreground="#6D28D9"
                       VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="320,*" ColumnSpacing="18">
            <Border Grid.Column="0"
                    Background="#F4F1FA"
                    BorderBrush="#CDB8F6"
                    BorderThickness="1.2"
                    CornerRadius="16"
                    BoxShadow="0 4 12 0 #22000000">
                <StackPanel>
                    <Border Height="120" Background="#E9DDFE" CornerRadius="16,16,0,0">
                        <Grid>
                            <Border Width="110" Height="110" CornerRadius="55" Background="#7C3AED" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <StackPanel Margin="16" Spacing="10">
                        <TextBlock Text="{Binding FullName}" FontSize="34" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding GroupName}" FontSize="14" Foreground="#5F5A70" HorizontalAlignment="Center"/>

                        <Border Background="#E9E3F2" CornerRadius="10" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Login" FontSize="12" Foreground="#6E6785"/>
                                <TextBlock Text="{Binding Login}" FontSize="14"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#E9E3F2" CornerRadius="10" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Role" FontSize="12" Foreground="#6E6785"/>
                                <TextBlock Text="{Binding RoleName}" FontSize="14"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="1" Spacing="14">
                <Border Background="#F4F1FA"
                        BorderBrush="#CDB8F6"
                        BorderThickness="1.2"
                        CornerRadius="16"
                        Padding="16"
                        BoxShadow="0 4 12 0 #22000000">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Learning Progress" FontSize="30" FontWeight="SemiBold"/>
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                            <Border Grid.Column="0" Background="White" BorderBrush="#CDB8F6" BorderThickness="1.2" CornerRadius="12" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="Lessons Completed" FontSize="12" Foreground="#6E6785"/>
                                    <TextBlock Text="{Binding LessonsCompletedText}" FontSize="26" Foreground="#7C3AED"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="White" BorderBrush="#CDB8F6" BorderThickness="1.2" CornerRadius="12" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="Tests Passed" FontSize="12" Foreground="#6E6785"/>
                                    <TextBlock Text="{Binding TestsCompleted}" FontSize="26" Foreground="#7C3AED"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="White" BorderBrush="#CDB8F6" BorderThickness="1.2" CornerRadius="12" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="Average Score" FontSize="12" Foreground="#6E6785"/>
                                    <TextBlock Text="{Binding AverageScoreText}" FontSize="26" Foreground="#7C3AED"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="#F4F1FA"
                        BorderBrush="#CDB8F6"
                        BorderThickness="1.2"
                        CornerRadius="16"
                        Padding="16"
                        BoxShadow="0 4 12 0 #22000000">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Recent Test Attempts" FontSize="30" FontWeight="SemiBold"/>

                        <ItemsControl ItemsSource="{Binding RecentTests}" IsVisible="{Binding HasRecentTests}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel ItemWidth="300"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.Styles>
                                <Style Selector="ContentPresenter">
                                    <Setter Property="Margin" Value="6"/>
                                </Style>
                            </ItemsControl.Styles>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White"
                                            BorderBrush="#CDB8F6"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="10">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding ResultText}" FontSize="12" Foreground="#5F5A70"/>
                                            <TextBlock Text="{Binding DateText}" FontSize="12" Foreground="#7C3AED"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
