<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="700"
             xmlns:vm="using:DiplomProject.ViewModels"
             x:DataType="vm:TeacherEulerViewModel"
             x:Class="DiplomProject.Views.TeacherEulerView">

    <UserControl.Styles>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#F9F8FD"/>
            <Setter Property="Foreground" Value="#6D28D9"/>
            <Setter Property="BorderBrush" Value="#CDB8F6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="#FEE2E2"/>
            <Setter Property="Foreground" Value="#DC2626"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBox.field">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CDB8F6"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </UserControl.Styles>

    <Grid Background="#F5F5F7" RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" Margin="28,18,28,0" ColumnDefinitions="Auto,*,Auto">
            <Button Grid.Column="0" Classes="secondary"
                    Command="{Binding NavigateBackCommand}">← Назад</Button>
            <TextBlock Grid.Column="1" Margin="16,0,0,0"
                       Text="Управление: Круги Эйлера"
                       FontSize="26" FontWeight="SemiBold" Foreground="#1A1625"
                       VerticalAlignment="Center"/>
            <TextBlock Grid.Column="2"
                       Text="{Binding StatusMessage}"
                       FontSize="13" Foreground="#7C3AED"
                       VerticalAlignment="Center"
                       IsVisible="{Binding HasStatus}"/>
        </Grid>

        <ScrollViewer Grid.Row="1" Margin="28,14,28,24">
            <StackPanel Spacing="14">

                <!-- Add Button -->
                <Button Classes="primary" HorizontalAlignment="Left"
                        Command="{Binding ShowAddFormCommand}">
                    + Добавить задачу
                </Button>

                <!-- Edit Form -->
                <Border Background="White" BorderBrush="#CDB8F6" BorderThickness="1.2"
                        CornerRadius="16" Padding="18"
                        IsVisible="{Binding IsFormVisible}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Редактирование задачи"
                                   FontSize="16" FontWeight="SemiBold" Foreground="#1A1625"/>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Заголовок" FontSize="13" Foreground="#6E6785"/>
                            <TextBox Classes="field" Text="{Binding EditTitle}"
                                     Watermark="Например: Пересечение множеств"/>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Описание / условие *" FontSize="13" Foreground="#6E6785"/>
                            <TextBox Classes="field" Text="{Binding EditDescription}"
                                     AcceptsReturn="True" Height="80"
                                     Watermark="Выберите область, соответствующую A ∩ B"/>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Сложность" FontSize="13" Foreground="#6E6785"/>
                            <ComboBox ItemsSource="{Binding Difficulties}"
                                      SelectedItem="{Binding EditDifficulty}"
                                      Background="White" BorderBrush="#CDB8F6"
                                      CornerRadius="8" Padding="10,8" MinWidth="120"/>
                        </StackPanel>

                        <!-- Region checkboxes -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Правильные области (отметьте все верные)"
                                       FontSize="13" Foreground="#6E6785"/>

                            <Border Background="#F9F8FD" BorderBrush="#E9D5FF"
                                    BorderThickness="1" CornerRadius="12" Padding="14">
                                <StackPanel Spacing="10">

                                    <!-- Visual hint -->
                                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                        <Border Grid.Column="0" Background="#EDE9FE" CornerRadius="8"
                                                Height="60" VerticalAlignment="Center">
                                            <TextBlock Text="Только A" FontSize="12"
                                                       Foreground="#7C3AED" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="1" Background="#DDD6FE" CornerRadius="8"
                                                Height="60" VerticalAlignment="Center">
                                            <TextBlock Text="A ∩ B" FontSize="12"
                                                       Foreground="#5B21B6" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="2" Background="#EDE9FE" CornerRadius="8"
                                                Height="60" VerticalAlignment="Center">
                                            <TextBlock Text="Только B" FontSize="12"
                                                       Foreground="#7C3AED" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>

                                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding EditAOnlyCorrect}"
                                                  Content="Только A (a-only)"
                                                  FontSize="13" Foreground="#2B2142"/>
                                        <CheckBox Grid.Column="1"
                                                  IsChecked="{Binding EditAbCorrect}"
                                                  Content="Пересечение (ab)"
                                                  FontSize="13" Foreground="#2B2142"/>
                                        <CheckBox Grid.Column="2"
                                                  IsChecked="{Binding EditBOnlyCorrect}"
                                                  Content="Только B (b-only)"
                                                  FontSize="13" Foreground="#2B2142"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Classes="primary" Command="{Binding SaveCommand}">Сохранить</Button>
                            <Button Classes="secondary" Command="{Binding CancelCommand}">Отмена</Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Problems List -->
                <ItemsControl ItemsSource="{Binding Problems}">
                    <ItemsControl.Styles>
                        <Style Selector="ContentPresenter">
                            <Setter Property="Margin" Value="0,4"/>
                        </Style>
                    </ItemsControl.Styles>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" BorderBrush="#CDB8F6" BorderThickness="1.2"
                                    CornerRadius="14" Padding="16">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="15" FontWeight="SemiBold"
                                                   Foreground="#1A1625"/>
                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="13" Foreground="#6E6785"
                                                   TextWrapping="Wrap" MaxWidth="520"/>
                                        <TextBlock Text="{Binding Difficulty, StringFormat='Сложность: {0}'}"
                                                   FontSize="12" Foreground="#7C3AED"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal" Spacing="6"
                                                VerticalAlignment="Center">
                                        <Button Classes="secondary"
                                                Command="{Binding $parent[UserControl].DataContext.ShowEditFormCommand}"
                                                CommandParameter="{Binding}">
                                            ✏ Изменить
                                        </Button>
                                        <Button Classes="danger"
                                                Command="{Binding $parent[UserControl].DataContext.DeleteCommand}"
                                                CommandParameter="{Binding}">
                                            🗑 Удалить
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
