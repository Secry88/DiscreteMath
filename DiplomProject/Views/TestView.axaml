<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="using:DiplomProject.ViewModels"
             x:DataType="vm:TestViewModel"
             x:Class="DiplomProject.Views.TestView">
    <UserControl.Styles>
        <Style Selector="Border.AnswerOption">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#A78BFA"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
        <Style Selector="Border.AnswerOption.selected">
            <Setter Property="Background" Value="#C4B5FD"/>
        </Style>
        <Style Selector="Button.AnswerButton:pointerover Border.AnswerOption">
            <Setter Property="Background" Value="#E9DDFE"/>
        </Style>
    </UserControl.Styles>

    <Grid Background="#F5F5F7" Margin="28,18,28,24">
        <Grid IsVisible="{Binding IsFinished}">
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="560"
                    Background="#F4F1FA"
                    BorderBrush="#0EA5E9"
                    BorderThickness="2.5"
                    CornerRadius="16"
                    Padding="24">
                <StackPanel Spacing="14" HorizontalAlignment="Center">
                    <Border Width="82" Height="82" CornerRadius="41" Background="#8B5CF6">
                        <TextBlock Text="🎉" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Task Completed" FontSize="34" FontWeight="SemiBold"/>
                    <TextBlock Text="You've finished the discrete mathematics test" FontSize="13" Foreground="#6E6785"/>
                    <Border Background="#DCCAF9" CornerRadius="16" Padding="20" Width="420">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="{Binding ResultPercent, StringFormat={}{0}%}" FontSize="62" Foreground="#6D28D9"/>
                            <TextBlock Text="{Binding ResultSummary}" FontSize="23" Foreground="#4C1D95"/>
                            <TextBlock Text="{Binding ResultAssessment}" FontSize="18" Foreground="#2B2142"/>
                        </StackPanel>
                    </Border>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="14" Width="420">
                        <Button Grid.Column="0"
                                Content="Back to Tests"
                                Command="{Binding BackToTestsCommand}"
                                Height="48"
                                CornerRadius="12"
                                BorderBrush="#8B5CF6"
                                BorderThickness="1.5"
                                Background="White"
                                Foreground="#6D28D9"/>
                        <Button Grid.Column="1"
                                Content="Retry Test"
                                Command="{Binding RetakeCommand}"
                                Height="48"
                                CornerRadius="12"
                                BorderThickness="0"
                                Background="#8B5CF6"
                                Foreground="White"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <Grid IsVisible="{Binding IsTakingTest}">
            <Grid RowDefinitions="Auto,*" RowSpacing="12">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                    <Button Grid.Column="0"
                            HorizontalAlignment="Left"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding BackToTestsCommand}">
                        <TextBlock Text="← Back to Test Selection" FontSize="17" Foreground="#2B2142"/>
                    </Button>
                    <Border Grid.Column="1"
                            Padding="18,8"
                            CornerRadius="12"
                            BorderBrush="#8B5CF6"
                            BorderThickness="1.4"
                            Background="#F9F8FD">
                        <TextBlock Text="{Binding QuestionProgress}" FontSize="14" Foreground="#2B2142"/>
                    </Border>
                </Grid>

                <Border Grid.Row="1"
                        HorizontalAlignment="Center"
                        Width="740"
                        Background="#F4F1FA"
                        BorderBrush="#CDB8F6"
                        BorderThickness="1.2"
                        CornerRadius="16"
                        Padding="24"
                        BoxShadow="0 4 12 0 #22000000">
                    <StackPanel Spacing="14">
                        <ProgressBar Minimum="0" Maximum="100" Value="{Binding ProgressValue}" Height="8" Foreground="#8B5CF6" Background="#E9DDFE"/>

                        <Border Background="#DCCAF9" CornerRadius="12" Padding="20,6" HorizontalAlignment="Left">
                            <TextBlock Text="{Binding QuestionProgress}" FontSize="13" Foreground="#4C1D95"/>
                        </Border>

                        <TextBlock Text="{Binding CurrentQuestion.QuestionText}"
                                   FontSize="34"
                                   FontWeight="SemiBold"
                                   Foreground="#151022"
                                   TextWrapping="Wrap"/>

                        <ItemsControl ItemsSource="{Binding CurrentQuestion.Answers}">
                            <ItemsControl.Styles>
                                <Style Selector="ContentPresenter">
                                    <Setter Property="Margin" Value="0,4"/>
                                </Style>
                            </ItemsControl.Styles>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Classes="AnswerButton"
                                            Command="{Binding $parent[UserControl].DataContext.SelectAnswerCommand}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0">
                                        <Border Classes="AnswerOption" Classes.selected="{Binding IsSelected}" Padding="14">
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                                <Border Width="18" Height="18" CornerRadius="9" BorderBrush="#8B5CF6" BorderThickness="1.5" Background="Transparent">
                                                    <Ellipse Width="8" Height="8" Fill="#8B5CF6" IsVisible="{Binding IsSelected}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="{Binding AnswerText}" FontSize="16" Foreground="#2B2142"/>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="10" Margin="0,10,0,0">
                            <Button Grid.Column="0"
                                    Content="Previous"
                                    Command="{Binding PreviousQuestionCommand}"
                                    IsEnabled="{Binding CanGoPrevious}"
                                    Height="46"
                                    Padding="18,0"
                                    CornerRadius="12"
                                    BorderBrush="#8B5CF6"
                                    BorderThickness="1.4"
                                    Background="White"
                                    Foreground="#6D28D9"/>
                            <Button Grid.Column="1"
                                    Content="Next"
                                    Command="{Binding NextQuestionCommand}"
                                    IsEnabled="{Binding CanGoNext}"
                                    Height="46"
                                    Padding="18,0"
                                    CornerRadius="12"
                                    BorderBrush="#8B5CF6"
                                    BorderThickness="1.4"
                                    Background="White"
                                    Foreground="#6D28D9"/>
                            <Button Grid.Column="3"
                                    Content="Finish Test"
                                    Command="{Binding FinishTestCommand}"
                                    IsEnabled="{Binding CanFinish}"
                                    Height="46"
                                    Padding="22,0"
                                    CornerRadius="12"
                                    BorderThickness="0"
                                    Background="#8B5CF6"
                                    Foreground="White"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
