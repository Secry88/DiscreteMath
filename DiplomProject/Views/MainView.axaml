<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="using:DiplomProject.ViewModels"
             xmlns:controls="using:DiplomProject.CustomControls"
             x:DataType="vm:MainViewModel"
             x:Class="DiplomProject.Views.MainView">

    <Grid Background="#F5F5F7">
        <Grid RowDefinitions="Auto,*">
            <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto"
                  Margin="56,28,56,20">
                <Grid Grid.Column="0" ColumnDefinitions="Auto,*" ColumnSpacing="16">
                    <Border Grid.Column="0"
                            Width="52"
                            Height="52"
                            CornerRadius="16"
                            Background="#7C3AED"
                            VerticalAlignment="Top">
                        <TextBlock Text="👋"
                                   FontSize="26"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock FontSize="44"
                                   FontWeight="SemiBold"
                                   Foreground="#6D28D9">
                            <Run Text="Welcome back, "/>
                            <Run Text="{Binding UserName}"/>
                            <Run Text="!"/>
                        </TextBlock>
                        <TextBlock Text="Let's continue learning discrete mathematics"
                                   FontSize="17"
                                   Foreground="#5F5A70"/>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="16"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top">
                    <Button Content="Profile"
                            Command="{Binding OpenProfileCommand}"
                            Padding="22,14"
                            MinWidth="120"
                            Background="#F9F8FD"
                            BorderBrush="#D9D3EA"
                            BorderThickness="1.5"
                            CornerRadius="15"
                            FontSize="20"
                            FontWeight="SemiBold"
                            Foreground="#6D28D9"/>

                    <Button Content="Logout"
                            Command="{Binding LogoutCommand}"
                            Padding="22,14"
                            MinWidth="120"
                            Background="#F9F8FD"
                            BorderBrush="#D9D3EA"
                            BorderThickness="1.5"
                            CornerRadius="15"
                            FontSize="20"
                            FontWeight="SemiBold"
                            Foreground="#6D28D9"/>
                </StackPanel>
            </Grid>

            <ItemsControl Grid.Row="1"
                          Margin="48,32,48,40"
                          HorizontalAlignment="Center"
                          MaxWidth="950"
                          ItemsSource="{Binding MenuItems}">
                <ItemsControl.Styles>
                    <Style Selector="ContentPresenter">
                        <Setter Property="Margin" Value="14"/>
                    </Style>
                </ItemsControl.Styles>

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel ItemWidth="280" ItemHeight="220"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:MenuCardControl Title="{Binding Title}"
                                                  Description="{Binding Description}"
                                                  Icon="{Binding Icon}"
                                                  Command="{Binding Command}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</UserControl>
