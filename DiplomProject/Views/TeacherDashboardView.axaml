<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             xmlns:vm="using:DiplomProject.ViewModels"
             x:DataType="vm:TeacherDashboardViewModel"
             x:Class="DiplomProject.Views.TeacherDashboardView">

    <Grid Background="#F5F5F7">
        <Grid RowDefinitions="Auto,*">

            <!-- HEADER -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="56,28,56,20">
                <Button Grid.Column="0"
                        HorizontalAlignment="Left" VerticalAlignment="Center"
                        Padding="0" Background="Transparent" BorderThickness="0"
                        Command="{Binding NavigateBackCommand}">
                    <TextBlock Text="← На главную" FontSize="17" Foreground="#6E6785"/>
                </Button>
                <Grid Grid.Column="1" ColumnDefinitions="Auto,*" ColumnSpacing="14"
                      Margin="24,0,0,0">
                    <Border Grid.Column="0" Width="52" Height="52" CornerRadius="16"
                            Background="#7C3AED" VerticalAlignment="Center">
                        <TextBlock Text="⚙️" FontSize="26"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="Панель преподавателя"
                                   FontSize="36" FontWeight="SemiBold" Foreground="#1A1625"/>
                        <TextBlock Text="Управление учебными материалами"
                                   FontSize="15" Foreground="#6E6785"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- CARDS AREA -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="40,16,40,40" Spacing="4">

                    <!-- Top row label -->
                    <TextBlock Text="Теория и проверка знаний" FontSize="13"
                               Foreground="#9CA3AF" Margin="14,8,0,0"/>

                    <!-- TOP ROW: Теория, Тесты -->
                    <WrapPanel HorizontalAlignment="Center">

                        <!-- Theory Card -->
                        <Button Width="320" Height="200" Margin="14"
                                Background="Transparent" BorderThickness="0" Padding="0"
                                Command="{Binding ManageTheoryCommand}">
                            <Border Background="White" CornerRadius="20" Padding="22"
                                    BorderBrush="#E9D5FF" BorderThickness="1.2"
                                    ClipToBounds="True" BoxShadow="0 4 14 0 #18000000">
                                <StackPanel Spacing="10">
                                    <Border Width="48" Height="48" Background="#EDE9FE"
                                            CornerRadius="12" HorizontalAlignment="Left">
                                        <TextBlock Text="📖" FontSize="24"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Теория" FontSize="19"
                                               FontWeight="SemiBold" Foreground="#1A1625"/>
                                    <TextBlock Text="Категории, темы, контент"
                                               FontSize="13" Foreground="#6B5B95" TextWrapping="Wrap"/>
                                    <TextBlock Text="Управлять ›" FontSize="13" Foreground="#7C3AED"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <!-- Tests Card -->
                        <Button Width="320" Height="200" Margin="14"
                                Background="Transparent" BorderThickness="0" Padding="0"
                                Command="{Binding ManageTestsCommand}">
                            <Border Background="White" CornerRadius="20" Padding="22"
                                    BorderBrush="#E9D5FF" BorderThickness="1.2"
                                    ClipToBounds="True" BoxShadow="0 4 14 0 #18000000">
                                <StackPanel Spacing="10">
                                    <Border Width="48" Height="48" Background="#EDE9FE"
                                            CornerRadius="12" HorizontalAlignment="Left">
                                        <TextBlock Text="🧪" FontSize="24"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Тесты" FontSize="19"
                                               FontWeight="SemiBold" Foreground="#1A1625"/>
                                    <TextBlock Text="Вопросы и ответы"
                                               FontSize="13" Foreground="#6B5B95" TextWrapping="Wrap"/>
                                    <TextBlock Text="Управлять ›" FontSize="13" Foreground="#7C3AED"/>
                                </StackPanel>
                            </Border>
                        </Button>

                    </WrapPanel>

                    <!-- Bottom row label -->
                    <TextBlock Text="Практические задания" FontSize="13"
                               Foreground="#9CA3AF" Margin="14,4,0,0"/>

                    <!-- BOTTOM ROW: Практика, Круги Эйлера, Пошаговые, Области -->
                    <WrapPanel HorizontalAlignment="Center">

                        <!-- Practice Card -->
                        <Button Width="320" Height="200" Margin="14"
                                Background="Transparent" BorderThickness="0" Padding="0"
                                Command="{Binding ManagePracticeCommand}">
                            <Border Background="White" CornerRadius="20" Padding="22"
                                    BorderBrush="#E9D5FF" BorderThickness="1.2"
                                    ClipToBounds="True" BoxShadow="0 4 14 0 #18000000">
                                <StackPanel Spacing="10">
                                    <Border Width="48" Height="48" Background="#EDE9FE"
                                            CornerRadius="12" HorizontalAlignment="Left">
                                        <TextBlock Text="✏️" FontSize="24"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Практика" FontSize="19"
                                               FontWeight="SemiBold" Foreground="#1A1625"/>
                                    <TextBlock Text="Задачи с множествами"
                                               FontSize="13" Foreground="#6B5B95" TextWrapping="Wrap"/>
                                    <TextBlock Text="Управлять ›" FontSize="13" Foreground="#7C3AED"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <!-- Euler Card -->
                        <Button Width="320" Height="200" Margin="14"
                                Background="Transparent" BorderThickness="0" Padding="0"
                                Command="{Binding ManageEulerCommand}">
                            <Border Background="White" CornerRadius="20" Padding="22"
                                    BorderBrush="#E9D5FF" BorderThickness="1.2"
                                    ClipToBounds="True" BoxShadow="0 4 14 0 #18000000">
                                <StackPanel Spacing="10">
                                    <Border Width="48" Height="48" Background="#EDE9FE"
                                            CornerRadius="12" HorizontalAlignment="Left">
                                        <TextBlock Text="🔵" FontSize="24"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Круги Эйлера" FontSize="19"
                                               FontWeight="SemiBold" Foreground="#1A1625"/>
                                    <TextBlock Text="Диаграммы и области"
                                               FontSize="13" Foreground="#6B5B95" TextWrapping="Wrap"/>
                                    <TextBlock Text="Управлять ›" FontSize="13" Foreground="#7C3AED"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <!-- Set Operation Card -->
                        <Button Width="320" Height="200" Margin="14"
                                Background="Transparent" BorderThickness="0" Padding="0"
                                Command="{Binding ManageSetOperationCommand}">
                            <Border Background="White" CornerRadius="20" Padding="22"
                                    BorderBrush="#E9D5FF" BorderThickness="1.2"
                                    ClipToBounds="True" BoxShadow="0 4 14 0 #18000000">
                                <StackPanel Spacing="10">
                                    <Border Width="48" Height="48" Background="#EDE9FE"
                                            CornerRadius="12" HorizontalAlignment="Left">
                                        <TextBlock Text="🔢" FontSize="24"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Пошаговые задания" FontSize="19"
                                               FontWeight="SemiBold" Foreground="#1A1625"/>
                                    <TextBlock Text="Операции над множествами"
                                               FontSize="13" Foreground="#6B5B95" TextWrapping="Wrap"/>
                                    <TextBlock Text="Управлять ›" FontSize="13" Foreground="#7C3AED"/>
                                </StackPanel>
                            </Border>
                        </Button>

                        <!-- Region Identification Card -->
                        <Button Width="320" Height="200" Margin="14"
                                Background="Transparent" BorderThickness="0" Padding="0"
                                Command="{Binding ManageRegionIdentificationCommand}">
                            <Border Background="White" CornerRadius="20" Padding="22"
                                    BorderBrush="#E9D5FF" BorderThickness="1.2"
                                    ClipToBounds="True" BoxShadow="0 4 14 0 #18000000">
                                <StackPanel Spacing="10">
                                    <Border Width="48" Height="48" Background="#EDE9FE"
                                            CornerRadius="12" HorizontalAlignment="Left">
                                        <TextBlock Text="📍" FontSize="24"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Области диаграмм" FontSize="19"
                                               FontWeight="SemiBold" Foreground="#1A1625"/>
                                    <TextBlock Text="Элементы и области"
                                               FontSize="13" Foreground="#6B5B95" TextWrapping="Wrap"/>
                                    <TextBlock Text="Управлять ›" FontSize="13" Foreground="#7C3AED"/>
                                </StackPanel>
                            </Border>
                        </Button>

                    </WrapPanel>

                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Grid>
</UserControl>
