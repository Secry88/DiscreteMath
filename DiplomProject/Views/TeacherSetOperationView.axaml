<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="980" d:DesignHeight="800"
             xmlns:vm="using:DiscreteMath.ViewModels"
             xmlns:models="using:DiscreteMath.Models"
             x:DataType="vm:TeacherSetOperationViewModel"
             x:Class="DiscreteMath.Views.TeacherSetOperationView">

    <UserControl.Styles>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#F9F8FD"/>
            <Setter Property="Foreground" Value="#6D28D9"/>
            <Setter Property="BorderBrush" Value="#CDB8F6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="#FEE2E2"/>
            <Setter Property="Foreground" Value="#DC2626"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.icon">
            <Setter Property="Background" Value="#EDE9FE"/>
            <Setter Property="Foreground" Value="#5B21B6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBox.field">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CDB8F6"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </UserControl.Styles>

    <Grid Background="#F5F5F7" RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" Margin="28,18,28,0" ColumnDefinitions="Auto,*,Auto">
            <Button Grid.Column="0" Classes="secondary" Command="{Binding NavigateBackCommand}">← Назад</Button>
            <TextBlock Grid.Column="1" Margin="16,0,0,0"
                       Text="Управление: Пошаговые задания"
                       FontSize="24" FontWeight="SemiBold" Foreground="#1A1625"
                       VerticalAlignment="Center"/>
            <TextBlock Grid.Column="2" Text="{Binding StatusMessage}"
                       FontSize="13" Foreground="#7C3AED" VerticalAlignment="Center"
                       IsVisible="{Binding HasStatus}"/>
        </Grid>

        <ScrollViewer Grid.Row="1" Margin="28,14,28,24">
            <StackPanel Spacing="14">

                <!-- Add button -->
                <Button Classes="primary" HorizontalAlignment="Left"
                        Command="{Binding ShowAddFormCommand}">+ Добавить задание</Button>

                <!-- Edit form -->
                <Border Background="White" BorderBrush="#CDB8F6" BorderThickness="1.2"
                        CornerRadius="16" Padding="18"
                        IsVisible="{Binding IsFormVisible}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Редактирование задания" FontSize="16"
                                   FontWeight="SemiBold" Foreground="#1A1625"/>

                        <!-- Row 1: Title + Expression -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="Заголовок" FontSize="13" Foreground="#6E6785"/>
                                <TextBox Classes="field" Text="{Binding EditTitle}"
                                         Watermark="Например: (A ∪ B) ∩ A"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="6">
                                <TextBlock Text="Выражение *" FontSize="13" Foreground="#6E6785"/>
                                <TextBox Classes="field" Text="{Binding EditExpression}"
                                         Watermark="(A ∪ B) ∩ A"/>
                            </StackPanel>
                        </Grid>

                        <!-- Description -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="Описание" FontSize="13" Foreground="#6E6785"/>
                            <TextBox Classes="field" Text="{Binding EditDescription}"
                                     AcceptsReturn="True" Height="60"
                                     Watermark="Дополнительное описание задания (необязательно)"/>
                        </StackPanel>

                        <!-- Row 2: Sets -->
                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="Множество A" FontSize="13" Foreground="#6E6785"/>
                                <TextBox Classes="field" Text="{Binding EditSetA}" Watermark="1,2,3"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="6">
                                <TextBlock Text="Множество B" FontSize="13" Foreground="#6E6785"/>
                                <TextBox Classes="field" Text="{Binding EditSetB}" Watermark="4,5,6"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="6">
                                <TextBlock Text="Множество C" FontSize="13" Foreground="#6E6785"/>
                                <TextBox Classes="field" Text="{Binding EditSetC}"
                                         Watermark="7,8,9 (для 3 множеств)"
                                         IsEnabled="{Binding IsEditingThreeSet}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Spacing="6">
                                <TextBlock Text="Универсальное U" FontSize="13" Foreground="#6E6785"/>
                                <TextBox Classes="field" Text="{Binding EditUniversalSet}" Watermark="1,...,9"/>
                            </StackPanel>
                        </Grid>

                        <!-- Row 3: DiagramType + Difficulty -->
                        <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="24">
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="Тип диаграммы" FontSize="13" Foreground="#6E6785"/>
                                <ComboBox ItemsSource="{Binding DiagramTypes}"
                                          SelectedItem="{Binding EditDiagramType}"
                                          Background="White" BorderBrush="#CDB8F6"
                                          CornerRadius="8" Padding="10,8" MinWidth="120"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="6">
                                <TextBlock Text="Сложность" FontSize="13" Foreground="#6E6785"/>
                                <ComboBox ItemsSource="{Binding Difficulties}"
                                          SelectedItem="{Binding EditDifficulty}"
                                          Background="White" BorderBrush="#CDB8F6"
                                          CornerRadius="8" Padding="10,8" MinWidth="100"/>
                            </StackPanel>
                        </Grid>

                        <!-- Steps section -->
                        <Border Background="#F9F8FD" BorderBrush="#E9D5FF" BorderThickness="1"
                                CornerRadius="12" Padding="14">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="Шаги решения"
                                               FontSize="14" FontWeight="SemiBold" Foreground="#1A1625"/>
                                    <Button Grid.Column="1" Classes="primary"
                                            Command="{Binding AddStepCommand}">+ Шаг</Button>
                                </Grid>

                                <TextBlock Text="Добавьте шаги в порядке решения. Пример: шаг 1 — вычислить A ∪ B, шаг 2 — пересечь с A."
                                           FontSize="12" Foreground="#6E6785" TextWrapping="Wrap"/>

                                <ItemsControl ItemsSource="{Binding EditSteps}">
                                    <ItemsControl.Styles>
                                        <Style Selector="ContentPresenter">
                                            <Setter Property="Margin" Value="0,4"/>
                                        </Style>
                                    </ItemsControl.Styles>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="White" BorderBrush="#DDD6FE"
                                                    BorderThickness="1" CornerRadius="10" Padding="12">
                                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                                                    <!-- Description -->
                                                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                                        <TextBlock Text="Описание шага" FontSize="12" Foreground="#6E6785"/>
                                                        <TextBox Background="White" BorderBrush="#CDB8F6"
                                                                 CornerRadius="6" Padding="8,6" FontSize="13"
                                                                 Text="{Binding Description}"
                                                                 Watermark="Что нужно вычислить на этом шаге"/>
                                                    </StackPanel>
                                                    <!-- Move + Delete buttons -->
                                                    <StackPanel Grid.Row="0" Grid.Column="1" Grid.RowSpan="3"
                                                                Orientation="Vertical" Spacing="4"
                                                                VerticalAlignment="Center" Margin="8,0,0,0">
                                                        <Button Classes="icon"
                                                                Command="{Binding $parent[UserControl].DataContext.MoveStepUpCommand}"
                                                                CommandParameter="{Binding}">↑</Button>
                                                        <Button Classes="icon"
                                                                Command="{Binding $parent[UserControl].DataContext.MoveStepDownCommand}"
                                                                CommandParameter="{Binding}">↓</Button>
                                                        <Button Classes="danger"
                                                                Command="{Binding $parent[UserControl].DataContext.RemoveStepCommand}"
                                                                CommandParameter="{Binding}">✕</Button>
                                                    </StackPanel>
                                                    <!-- Expression -->
                                                    <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                                                        <TextBlock Text="Выражение шага" FontSize="12" Foreground="#6E6785"/>
                                                        <TextBox Background="White" BorderBrush="#CDB8F6"
                                                                 CornerRadius="6" Padding="8,6" FontSize="13"
                                                                 Text="{Binding Expression}"
                                                                 Watermark="A ∪ B"/>
                                                    </StackPanel>
                                                    <!-- Correct answer -->
                                                    <StackPanel Grid.Row="2" Grid.Column="0" Spacing="4">
                                                        <TextBlock Text="Правильный ответ" FontSize="12" Foreground="#6E6785"/>
                                                        <TextBox Background="White" BorderBrush="#CDB8F6"
                                                                 CornerRadius="6" Padding="8,6" FontSize="13"
                                                                 Text="{Binding CorrectAnswer}"
                                                                 Watermark="1,2,3,4"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Correct regions -->
                        <Border Background="#F9F8FD" BorderBrush="#E9D5FF" BorderThickness="1"
                                CornerRadius="12" Padding="14">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Правильные области диаграммы (отметьте все верные)"
                                           FontSize="14" FontWeight="SemiBold" Foreground="#1A1625"/>

                                <!-- 2-set regions (always visible) -->
                                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                                    <Border Grid.Column="0" Background="#EDE9FE" CornerRadius="8" Height="50">
                                        <TextBlock Text="Только A" FontSize="12" Foreground="#7C3AED"
                                                   FontWeight="SemiBold" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Column="1" Background="#DDD6FE" CornerRadius="8" Height="50">
                                        <TextBlock Text="A ∩ B" FontSize="12" Foreground="#5B21B6"
                                                   FontWeight="SemiBold" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Column="2" Background="#EDE9FE" CornerRadius="8" Height="50">
                                        <TextBlock Text="Только B" FontSize="12" Foreground="#7C3AED"
                                                   FontWeight="SemiBold" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Column="3" Background="#F3F0FB" CornerRadius="8" Height="50">
                                        <TextBlock Text="Вне множеств" FontSize="12" Foreground="#7C3AED"
                                                   FontWeight="SemiBold" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                                    <CheckBox Grid.Column="0" IsChecked="{Binding EditAOnlyCorrect}"
                                              Content="a-only" FontSize="13" Foreground="#2B2142"/>
                                    <CheckBox Grid.Column="1" IsChecked="{Binding EditAbCorrect}"
                                              Content="ab" FontSize="13" Foreground="#2B2142"/>
                                    <CheckBox Grid.Column="2" IsChecked="{Binding EditBOnlyCorrect}"
                                              Content="b-only" FontSize="13" Foreground="#2B2142"/>
                                    <CheckBox Grid.Column="3" IsChecked="{Binding EditOutsideCorrect}"
                                              Content="outside" FontSize="13" Foreground="#2B2142"/>
                                </Grid>

                                <!-- 3-set extra regions -->
                                <StackPanel IsVisible="{Binding IsEditingThreeSet}" Spacing="8">
                                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                                        <Border Grid.Column="0" Background="#DDD6FE" CornerRadius="8" Height="50">
                                            <TextBlock Text="A ∩ C" FontSize="12" Foreground="#5B21B6"
                                                       FontWeight="SemiBold" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="1" Background="#C4B5FD" CornerRadius="8" Height="50">
                                            <TextBlock Text="A ∩ B ∩ C" FontSize="12" Foreground="#3730A3"
                                                       FontWeight="SemiBold" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="2" Background="#DDD6FE" CornerRadius="8" Height="50">
                                            <TextBlock Text="B ∩ C" FontSize="12" Foreground="#5B21B6"
                                                       FontWeight="SemiBold" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="3" Background="#EDE9FE" CornerRadius="8" Height="50">
                                            <TextBlock Text="Только C" FontSize="12" Foreground="#7C3AED"
                                                       FontWeight="SemiBold" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                                        <CheckBox Grid.Column="0" IsChecked="{Binding EditAcCorrect}"
                                                  Content="ac" FontSize="13" Foreground="#2B2142"/>
                                        <CheckBox Grid.Column="1" IsChecked="{Binding EditAbcCorrect}"
                                                  Content="abc" FontSize="13" Foreground="#2B2142"/>
                                        <CheckBox Grid.Column="2" IsChecked="{Binding EditBcCorrect}"
                                                  Content="bc" FontSize="13" Foreground="#2B2142"/>
                                        <CheckBox Grid.Column="3" IsChecked="{Binding EditCOnlyCorrect}"
                                                  Content="c-only" FontSize="13" Foreground="#2B2142"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Save/Cancel -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Classes="primary" Command="{Binding SaveCommand}">Сохранить</Button>
                            <Button Classes="secondary" Command="{Binding CancelCommand}">Отмена</Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Tasks list -->
                <ItemsControl ItemsSource="{Binding Tasks}">
                    <ItemsControl.Styles>
                        <Style Selector="ContentPresenter">
                            <Setter Property="Margin" Value="0,4"/>
                        </Style>
                    </ItemsControl.Styles>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" BorderBrush="#CDB8F6" BorderThickness="1.2"
                                    CornerRadius="14" Padding="16">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="{Binding Title}" FontSize="15"
                                                   FontWeight="SemiBold" Foreground="#1A1625"/>
                                        <TextBlock Text="{Binding Expression}" FontSize="18"
                                                   Foreground="#5B21B6" FontWeight="SemiBold"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding DiagramType, StringFormat='Множеств: {0}'}"
                                                       FontSize="12" Foreground="#6E6785"/>
                                            <TextBlock Text="{Binding Difficulty, StringFormat='Сложность: {0}'}"
                                                       FontSize="12" Foreground="#7C3AED"/>
                                            <TextBlock Text="{Binding Steps.Count, StringFormat='Шагов: {0}'}"
                                                       FontSize="12" Foreground="#6E6785"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}" FontSize="12"
                                                   Foreground="#6E6785" TextWrapping="Wrap" MaxWidth="520"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                                                VerticalAlignment="Center">
                                        <Button Classes="secondary"
                                                Command="{Binding $parent[UserControl].DataContext.ShowEditFormCommand}"
                                                CommandParameter="{Binding}">✏ Изменить</Button>
                                        <Button Classes="danger"
                                                Command="{Binding $parent[UserControl].DataContext.DeleteCommand}"
                                                CommandParameter="{Binding}">🗑 Удалить</Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
