<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="using:DiscreteMath.ViewModels"
             x:DataType="vm:TestSelectionViewModel"
             x:Class="DiscreteMath.Views.TestSelectionView">
    <UserControl.Styles>
        <Style Selector="Border.DifficultyChip">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10,2"/>
        </Style>
        <Style Selector="Border.DifficultyChip.easy">
            <Setter Property="Background" Value="#BBF7D0"/>
        </Style>
        <Style Selector="Border.DifficultyChip.medium">
            <Setter Property="Background" Value="#FED7AA"/>
        </Style>
        <Style Selector="Border.DifficultyChip.hard">
            <Setter Property="Background" Value="#FCA5A5"/>
        </Style>
    </UserControl.Styles>

    <Grid Background="#F5F5F7" RowDefinitions="Auto,*" Margin="28,18,28,24">
        <Button Grid.Row="0"
                HorizontalAlignment="Left"
                Padding="0"
                Background="Transparent"
                BorderThickness="0"
                Command="{Binding NavigateBackCommand}">
            <TextBlock Text="← Back to Dashboard"
                       FontSize="17"
                       Foreground="#2B2142"/>
        </Button>

        <ScrollViewer Grid.Row="1" Margin="0,12,0,0">
            <StackPanel Spacing="12">
                <StackPanel Spacing="2">
                    <TextBlock Text="Tests"
                               FontSize="34"
                               FontWeight="SemiBold"
                               Foreground="#151022"/>
                    <TextBlock Text="Select a test to evaluate your knowledge"
                               FontSize="14"
                               Foreground="#6E6785"/>
                </StackPanel>

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                    <Border Grid.Column="0" Background="#F9F8FD" BorderBrush="#CDB8F6" BorderThickness="1.2" CornerRadius="12" Padding="10">
                        <StackPanel>
                            <TextBlock Text="{Binding AvailableTestsCount}" FontSize="18" Foreground="#4C1D95"/>
                            <TextBlock Text="Available Tests" FontSize="12" Foreground="#6E6785"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="#F9F8FD" BorderBrush="#CDB8F6" BorderThickness="1.2" CornerRadius="12" Padding="10">
                        <StackPanel>
                            <TextBlock Text="{Binding CompletedCount}" FontSize="18" Foreground="#4C1D95"/>
                            <TextBlock Text="Completed" FontSize="12" Foreground="#6E6785"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="#F9F8FD" BorderBrush="#CDB8F6" BorderThickness="1.2" CornerRadius="12" Padding="10">
                        <StackPanel>
                            <TextBlock Text="{Binding AverageScoreText}" FontSize="18" Foreground="#4C1D95"/>
                            <TextBlock Text="Average Score" FontSize="12" Foreground="#6E6785"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <ItemsControl ItemsSource="{Binding Tests}">
                    <ItemsControl.Styles>
                        <Style Selector="ContentPresenter">
                            <Setter Property="Margin" Value="0,2,0,6"/>
                        </Style>
                    </ItemsControl.Styles>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White"
                                    BorderBrush="#CDB8F6"
                                    BorderThickness="1.2"
                                    CornerRadius="14"
                                    Padding="14"
                                    BoxShadow="0 4 12 0 #22000000">
                                <StackPanel Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <TextBlock Text="{Binding Title}" FontSize="23" FontWeight="SemiBold" Foreground="#151022"/>
                                            <TextBlock Text="{Binding Description}" FontSize="13" Foreground="#6E6785" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <Border Grid.Column="1"
                                                Classes="DifficultyChip"
                                                Classes.easy="{Binding IsEasy}"
                                                Classes.medium="{Binding IsMedium}"
                                                Classes.hard="{Binding IsHard}">
                                            <TextBlock Text="{Binding DifficultyLabel}" FontSize="12"/>
                                        </Border>
                                    </Grid>

                                    <TextBlock Text="{Binding Topic}" FontSize="13" Foreground="#7C3AED"/>

                                    <Separator Background="#E6DDF8"/>

                                    <Grid ColumnDefinitions="Auto,Auto,*,Auto" VerticalAlignment="Center">
                                        <TextBlock Grid.Column="0" Text="{Binding QuestionsCount, StringFormat={}{0} questions}" FontSize="13" Foreground="#2B2142"/>
                                        <TextBlock Grid.Column="1" Margin="16,0,0,0" Text="{Binding DurationMinutes, StringFormat={}{0} min}" FontSize="13" Foreground="#2B2142"/>

                                        <Button Grid.Column="3"
                                                Content="{Binding StartButtonText}"
                                                Command="{Binding $parent[UserControl].DataContext.StartTestCommand}"
                                                CommandParameter="{Binding}"
                                                Padding="16,8"
                                                CornerRadius="10"
                                                BorderThickness="0"
                                                Foreground="White"
                                                Background="#8B5CF6"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
