<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="700"
             xmlns:vm="using:DiscreteMath.ViewModels"
             x:DataType="vm:TeacherPracticeViewModel"
             x:Class="DiscreteMath.Views.TeacherPracticeView">

    <UserControl.Styles>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#F9F8FD"/>
            <Setter Property="Foreground" Value="#6D28D9"/>
            <Setter Property="BorderBrush" Value="#CDB8F6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="#FEE2E2"/>
            <Setter Property="Foreground" Value="#DC2626"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBox.field">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CDB8F6"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </UserControl.Styles>

    <Grid Background="#F5F5F7" RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" Margin="28,18,28,0" ColumnDefinitions="Auto,*,Auto">
            <Button Grid.Column="0" Classes="secondary"
                    Command="{Binding NavigateBackCommand}">← Назад</Button>
            <TextBlock Grid.Column="1" Margin="16,0,0,0"
                       Text="Управление: Практика"
                       FontSize="26" FontWeight="SemiBold" Foreground="#1A1625"
                       VerticalAlignment="Center"/>
            <TextBlock Grid.Column="2"
                       Text="{Binding StatusMessage}"
                       FontSize="14" Foreground="#7C3AED"
                       VerticalAlignment="Center"
                       IsVisible="{Binding HasStatus}"/>
        </Grid>

        <ScrollViewer Grid.Row="1" Margin="28,14,28,24">
            <StackPanel Spacing="14">

                <!-- Add Button -->
                <Button Classes="primary" HorizontalAlignment="Left"
                        Command="{Binding ShowAddFormCommand}">
                    + Добавить задачу
                </Button>

                <!-- Edit Form -->
                <Border Background="White" BorderBrush="#CDB8F6" BorderThickness="1.2"
                        CornerRadius="16" Padding="18"
                        IsVisible="{Binding IsFormVisible}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Новая / редактируемая задача"
                                   FontSize="16" FontWeight="SemiBold" Foreground="#1A1625"/>
                        <Grid ColumnDefinitions="*,16,*">
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="Множество A (через запятую)" FontSize="14" Foreground="#6E6785"/>
                                <TextBox Classes="field" Text="{Binding EditSetA}" Watermark="1,2,3"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="6">
                                <TextBlock Text="Множество B (через запятую)" FontSize="14" Foreground="#6E6785"/>
                                <TextBox Classes="field" Text="{Binding EditSetB}" Watermark="4,5,6"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Операция" FontSize="14" Foreground="#6E6785"/>
                            <ComboBox ItemsSource="{Binding Operations}"
                                      SelectedItem="{Binding EditOperation}"
                                      Background="White" BorderBrush="#CDB8F6"
                                      CornerRadius="8" Padding="10,8" MinWidth="200"/>
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Условие (текст задачи) *" FontSize="14" Foreground="#6E6785"/>
                            <TextBox Classes="field" Text="{Binding EditCondition}"
                                     AcceptsReturn="True" Height="72"
                                     Watermark="A = {1,2,3}, B = {2,4}. Найдите A ∪ B"/>
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Правильный ответ (через запятую)" FontSize="14" Foreground="#6E6785"/>
                            <TextBox Classes="field" Text="{Binding EditCorrectAnswer}" Watermark="1,2,3,4"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Classes="primary" Command="{Binding SaveCommand}">Сохранить</Button>
                            <Button Classes="secondary" Command="{Binding CancelCommand}">Отмена</Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Tasks List -->
                <ItemsControl ItemsSource="{Binding Tasks}">
                    <ItemsControl.Styles>
                        <Style Selector="ContentPresenter">
                            <Setter Property="Margin" Value="0,4"/>
                        </Style>
                    </ItemsControl.Styles>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" BorderBrush="#CDB8F6" BorderThickness="1.2"
                                    CornerRadius="14" Padding="16">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="{Binding Condition}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="#1A1625" TextWrapping="Wrap"/>
                                        <StackPanel Orientation="Horizontal" Spacing="16">
                                            <TextBlock Text="{Binding Operation, StringFormat='Операция: {0}'}"
                                                       FontSize="14" Foreground="#7C3AED"/>
                                            <TextBlock Text="{Binding CorrectAnswer, StringFormat='Ответ: {0}'}"
                                                       FontSize="14" Foreground="#6E6785"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding SetA, StringFormat='A = \\{{0}\\}'}"
                                                       FontSize="14" Foreground="#6E6785"/>
                                            <TextBlock Text="{Binding SetB, StringFormat='B = \\{{0}\\}'}"
                                                       FontSize="14" Foreground="#6E6785"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal" Spacing="6"
                                                VerticalAlignment="Center">
                                        <Button Classes="secondary"
                                                Command="{Binding $parent[UserControl].DataContext.ShowEditFormCommand}"
                                                CommandParameter="{Binding}">
                                            ✏ Изменить
                                        </Button>
                                        <Button Classes="danger"
                                                Command="{Binding $parent[UserControl].DataContext.DeleteCommand}"
                                                CommandParameter="{Binding}">
                                            🗑 Удалить
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
